  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-zinc-500 dark:text-zinc-400">
    <p>© {year} Gaurav Agarwal. All rights reserved.</p>
    <div class="flex items-center gap-5">
      <a href="/resume" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Résumé</a>
      <a href="https://blog.algogrit.com" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Blog</a>
      <a href="https://github.com/algogrit" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 dark:hover:text-white transition-colors">GitHub</a>
    </div>
  </div>
</footer>
