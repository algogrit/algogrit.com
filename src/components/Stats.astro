---
const stats = [
  { value: '12+', label: 'Years Experience' },
  { value: '3000+', label: 'Engineers Trained' },
  { value: '35+', label: 'Enterprise Clients' },
  { value: '14+', label: 'Languages' },
];
---
<section class="px-6 py-24">
  <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
    {
      stats.map((s, i) => (
        <div class="reveal" style={`--d:${i * 80}ms`}>
          <div class="display text-5xl md:text-6xl font-bold grad">{s.value}</div>
          <div class="mt-2 text-zinc-500 dark:text-zinc-400">{s.label}</div>
        </div>
      ))
    }
  </div>
</section>
