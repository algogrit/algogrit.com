---
<section id="resume" class="px-6 py-20">
  <div class="max-w-5xl mx-auto reveal">
    <div class="gborder rounded-3xl glass p-10 md:p-14 flex flex-col md:flex-row md:items-center justify-between gap-8">
      <div>
        <h2 class="display text-3xl md:text-4xl font-bold mb-3">
          The full <span class="grad">résumé.</span>
        </h2>
        <p class="text-zinc-600 dark:text-zinc-400 max-w-md">
          A complete, printable overview of my experience, projects, skills and education — ready to
          save as a PDF.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a
          href="/resume"
          class="px-7 py-3.5 rounded-full text-white font-semibold grad-bg hover:opacity-90 transition-opacity"
        >
          View résumé →
        </a>
        <a
          href="/resume?print=1"
          class="px-7 py-3.5 rounded-full font-semibold glass hover:scale-[1.03] transition-transform"
        >
          Download PDF
        </a>
      </div>
    </div>
  </div>
</section>
