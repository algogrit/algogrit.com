---
import { community, communityNote } from '../data/community';
---
<section id="community" class="px-6 py-24">
  <div class="max-w-6xl mx-auto">
    <h2 class="display text-5xl md:text-6xl font-bold mb-4 reveal">
      Community &amp;<br /><span class="grad">Speaking.</span>
    </h2>
    <p class="text-zinc-500 dark:text-zinc-400 max-w-2xl mb-12 reveal">{communityNote}</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        community.map((c, i) => {
          const Tag = c.link ? 'a' : 'div';
          return (
            <Tag
              href={c.link}
              target={c.link ? '_blank' : undefined}
              rel={c.link ? 'noopener noreferrer' : undefined}
              class:list={['card rounded-2xl p-6 reveal block', c.link && 'lift']}
              style={`--d:${(i % 3) * 80}ms`}
            >
              <div class="grad display text-lg font-bold">{c.org}</div>
              <div class="mt-1 text-sm text-zinc-600 dark:text-zinc-300">{c.role}</div>
              {c.note && <div class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400">{c.note}</div>}
              {c.link && <div class="mt-3 text-xs grad font-semibold">Visit ↗</div>}
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>
