---
import { experience } from '../data/experience';
---
<section id="experience" class="px-6 py-24">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-16">
      <h2 class="display text-5xl md:text-6xl font-bold reveal">
        Career<br /><span class="grad">Highlights.</span>
      </h2>
      <a href="/resume" class="grad font-semibold hover:underline reveal text-sm">Full résumé →</a>
    </div>

    <div class="relative border-l border-zinc-200 dark:border-white/10 ml-2 space-y-6">
      {
        experience.map((job, i) => (
          <div class="relative pl-8 reveal" style={`--d:${Math.min(i, 4) * 60}ms`}>
            <span
              class:list={[
                'absolute -left-[6px] top-7 h-3 w-3 rounded-full ring-4',
                job.current
                  ? 'grad-bg ring-fuchsia-500/15'
                  : 'bg-zinc-300 dark:bg-zinc-600 ring-zinc-400/10',
              ]}
            />
            <div class="card rounded-2xl p-6">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <h3 class="display text-xl font-bold">{job.position}</h3>
                  {job.link ? (
                    <a href={job.link} target="_blank" rel="noopener noreferrer" class="grad font-semibold hover:underline">
                      {job.company}
                    </a>
                  ) : (
                    <span class="text-zinc-500 dark:text-zinc-400 font-medium">{job.company}</span>
                  )}
                </div>
                <div class="flex items-center gap-2 text-xs shrink-0">
                  {job.current && (
                    <span class="px-2.5 py-1 rounded-full grad-bg text-white font-medium">Current</span>
                  )}
                  <span class="px-2.5 py-1 rounded-full bg-zinc-100 dark:bg-white/5 text-zinc-500 dark:text-zinc-400">
                    {job.period}
                  </span>
                </div>
              </div>
              <p class="mt-3 text-zinc-600 dark:text-zinc-400 text-sm">{job.description}</p>
              {job.current && (
                <ul class="mt-4 space-y-2 text-sm text-zinc-600 dark:text-zinc-300">
                  {job.achievements.slice(0, 3).map((a) => (
                    <li class="flex gap-2.5">
                      <span class="grad font-bold">→</span>
                      {a}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
