---
import { experience } from '../data/experience';
const last = experience.length - 1;
---
<section id="experience" class="px-6 py-24">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-16">
      <h2 class="display text-5xl md:text-6xl font-bold reveal">
        Career<br /><span class="grad">Highlights.</span>
      </h2>
      <a href="/resume" class="grad font-semibold hover:underline reveal text-sm">Full résumé →</a>
    </div>

    <div class="relative ml-2 space-y-6">
      {
        experience.map((job, i) => (
          <div class="relative pl-8 reveal" style={`--d:${Math.min(i, 4) * 60}ms`}>
            {/* connector line - stops at the last dot */}
            {i !== last && (
              <span
                class="absolute left-0 -translate-x-1/2 top-7 w-px bg-zinc-200 dark:bg-white/10"
                style="height: calc(100% + 1.5rem)"
                aria-hidden="true"
              />
            )}
            {/* node dot */}
            <span
              class:list={[
                'absolute left-0 -translate-x-1/2 top-7 h-3 w-3 rounded-full ring-4 z-10',
                job.current ? 'grad-bg ring-fuchsia-500/15' : 'bg-zinc-300 dark:bg-zinc-600 ring-zinc-400/10',
              ]}
              aria-hidden="true"
            />

            <details name="exp" class="card rounded-2xl group" open={i === 0}>
              <summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden p-6">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <h3 class="display text-xl font-bold">{job.position}</h3>
                    {job.link ? (
                      <a
                        href={job.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="grad font-semibold hover:underline"
                        onclick="event.stopPropagation()"
                      >
                        {job.company}
                      </a>
                    ) : (
                      <span class="text-zinc-500 dark:text-zinc-400 font-medium">{job.company}</span>
                    )}
                  </div>
                  <div class="flex items-center gap-2 text-xs shrink-0">
                    {job.current && (
                      <span class="px-2.5 py-1 rounded-full grad-bg text-white font-medium">Current</span>
                    )}
                    <span class="px-2.5 py-1 rounded-full bg-zinc-100 dark:bg-white/5 text-zinc-500 dark:text-zinc-400">
                      {job.period}
                    </span>
                    <svg
                      class="w-4 h-4 text-zinc-400 transition-transform duration-300 group-open:rotate-180"
                      fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
                    </svg>
                  </div>
                </div>
              </summary>

              <div class="px-6 pb-6 -mt-1">
                <p class="text-zinc-600 dark:text-zinc-400 text-sm">{job.description}</p>

                {job.achievements.length > 0 && (
                  <ul class="mt-4 space-y-2 text-sm text-zinc-600 dark:text-zinc-300">
                    {job.achievements.map((a) => (
                      <li class="flex gap-2.5">
                        <span class="grad font-bold">→</span>
                        {a}
                      </li>
                    ))}
                  </ul>
                )}

                {job.projects && job.projects.length > 0 && (
                  <div class="mt-5 space-y-3">
                    <div class="text-xs uppercase tracking-widest text-zinc-400">Notable projects</div>
                    {job.projects.map((p) => (
                      <div class="rounded-xl border border-zinc-200 dark:border-white/5 bg-zinc-50 dark:bg-white/[0.02] p-4">
                        <h4 class="font-semibold text-sm">
                          {p.name}
                          {p.link && (
                            <a href={p.link} target="_blank" rel="noopener noreferrer" class="grad font-normal"> ↗</a>
                          )}
                        </h4>
                        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">{p.description}</p>
                        <div class="flex flex-wrap gap-1.5 mt-2.5">
                          {p.technologies.map((t) => (
                            <span class="px-2 py-0.5 rounded-md text-xs bg-zinc-200/70 dark:bg-white/10">{t}</span>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </details>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  // Keep the clicked role under the pointer: when opening one item collapses a
  // taller item above it, the page would shift up. Compensate the scroll so the
  // summary stays at the same viewport position.
  (() => {
    document.querySelectorAll('#experience details > summary').forEach((sum) => {
      sum.addEventListener('click', () => {
        const before = sum.getBoundingClientRect().top;
        requestAnimationFrame(() => {
          const delta = sum.getBoundingClientRect().top - before;
          if (delta) window.scrollBy({ top: delta, left: 0, behavior: 'instant' });
        });
      });
    });
  })();
</script>
