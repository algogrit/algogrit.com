---
import { skillCategories } from '../data/skills';

const shortName: Record<string, string> = {
  'Programming Languages': 'Languages',
  'Tools & Frameworks': 'Frameworks',
  'Infrastructure & Data': 'Infra & Data',
  Platforms: 'Platforms',
};

const cats = skillCategories.map((c) => ({
  key: shortName[c.name].toLowerCase().replace(/[^a-z]+/g, '-'),
  name: shortName[c.name],
  count: c.skills.length,
  sample: c.skills.slice(0, 6).map((s) => s.name).join(', '),
  icons: c.skills.map((s) => ({ src: s.src, name: s.name })),
}));

// Two synced marquee layers (like codermana):
//  - BASE: theme-aware monochrome silhouettes (always visible), faded.
//  - COLOR: real brand colours, masked to a centre "spotlight".
// Both layers are the SAME size, so the silhouette and colour copy of an icon
// overlap perfectly through the spotlight crossfade (clean gray→colour fade).
const BASE_ICON = 'h-9 w-9 object-contain brightness-0 dark:invert';
const COLOR_ICON = 'h-9 w-9 object-contain';
// Complementary masks so the two synced layers never overlap (no ghosting):
// silhouettes show only at the edges, colour only through the centre spotlight.
const EDGE_MASK =
  'linear-gradient(to right,#000 0%,#000 20%,transparent 40%,transparent 60%,#000 80%,#000 100%)';
const CENTER_MASK =
  'linear-gradient(to right,transparent 0%,transparent 20%,#000 40%,#000 60%,transparent 80%,transparent 100%)';
const BASE_STYLE = `-webkit-mask-image:${EDGE_MASK};mask-image:${EDGE_MASK}`;
const SPOTLIGHT = `-webkit-mask-image:${CENTER_MASK};mask-image:${CENTER_MASK}`;

// "all" view: each category's icons, followed by a dot separator between groups
const allItems = cats.flatMap((c) => [
  ...c.icons.map((ic) => ({ type: 'icon', ...ic })),
  { type: 'sep' },
]);
const initial = [...allItems, ...allItems];
---
<section id="skills" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="display text-5xl md:text-6xl font-bold mb-3 reveal">Skills.</h2>
    <p id="skill-hint" class="text-zinc-500 dark:text-zinc-400 mb-10 reveal">
      Languages, frameworks, infrastructure &amp; platforms — tap a category to filter.
    </p>
  </div>

  <!-- ticker: silhouette base + colour spotlight. Both masks live on FIXED
       (non-animated) overlays, so the spotlight stays put while identical
       tracks scroll through it. -->
  <div class="marquee-pausable relative overflow-hidden mb-10">
    <!-- sizer: gives the wrapper height (both layers are absolute) -->
    <div class="h-12 invisible" aria-hidden="true"></div>

    <!-- base silhouettes — visible at the edges only -->
    <div class="absolute inset-0 flex items-center" style={BASE_STYLE} aria-hidden="true">
      <div id="skill-track-base" class="flex gap-14 w-max marquee items-center opacity-60 dark:opacity-70 will-change-transform">
        {
          initial.map((it) =>
            it.type === 'sep' ? (
              <span class="h-1.5 w-1.5 rounded-full bg-zinc-400/70 dark:bg-zinc-500 shrink-0" />
            ) : (
              <img src={it.src} alt="" title={it.name} loading="lazy" class={BASE_ICON} />
            )
          )
        }
      </div>
    </div>

    <!-- light strip behind the spotlight (dark mode), aids legibility -->
    <div
      class="absolute inset-0 hidden dark:block pointer-events-none"
      style="background:linear-gradient(to right,transparent 32%,rgba(255,255,255,.06) 45%,rgba(255,255,255,.06) 55%,transparent 68%)"
      aria-hidden="true"
    >
    </div>

    <!-- colour spotlight — visible through the centre only -->
    <div class="absolute inset-0 flex items-center pointer-events-none" style={SPOTLIGHT} aria-hidden="true">
      <div id="skill-track-color" class="flex gap-14 w-max marquee items-center will-change-transform">
        {
          initial.map((it) =>
            it.type === 'sep' ? (
              <span class="h-1.5 w-1.5 rounded-full grad-bg shrink-0" />
            ) : (
              <img src={it.src} alt="" title={it.name} loading="lazy" class={COLOR_ICON} />
            )
          )
        }
      </div>
    </div>
  </div>

  <!-- category cards (filter buttons) -->
  <div class="max-w-6xl mx-auto px-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {
      cats.map((c, i) => (
        <button
          type="button"
          class="cat-card card rounded-2xl p-6 text-left reveal"
          data-cat={c.key}
          aria-pressed="false"
          style={`--d:${i * 80}ms`}
        >
          <div class="cat-count display text-3xl font-bold grad">{c.count}</div>
          <h3 class="font-semibold mt-1">{c.name}</h3>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">{c.sample}…</p>
        </button>
      ))
    }
  </div>
</section>

<script is:inline define:vars={{ cats, BASE_ICON, COLOR_ICON }}>
  (() => {
    const base = document.getElementById('skill-track-base');
    const color = document.getElementById('skill-track-color');
    const hint = document.getElementById('skill-hint');
    const cards = Array.from(document.querySelectorAll('.cat-card'));
    if (!base || !color) return;

    let active = null;

    const SEP_BASE = '<span class="h-1.5 w-1.5 rounded-full bg-zinc-400/70 dark:bg-zinc-500 shrink-0"></span>';
    const SEP_COLOR = '<span class="h-1.5 w-1.5 rounded-full grad-bg shrink-0"></span>';
    const img = (s, cls) => `<img src="${s.src}" alt="" title="${s.name}" loading="lazy" class="${cls}">`;

    // single category → just its icons; "all" → icons grouped by a dot separator
    const itemsFor = (key) => {
      const cat = key ? cats.find((c) => c.key === key) : null;
      return cat
        ? cat.icons.map((ic) => ({ type: 'icon', ...ic }))
        : cats.flatMap((c) => [...c.icons.map((ic) => ({ type: 'icon', ...ic })), { type: 'sep' }]);
    };

    function render(key) {
      const list = itemsFor(key);
      const build = (sep, cls) => {
        const html = list.map((it) => (it.type === 'sep' ? sep : img(it, cls))).join('');
        return html + html + (list.length < 10 ? html + html : '');
      };
      base.innerHTML = build(SEP_BASE, BASE_ICON);
      color.innerHTML = build(SEP_COLOR, COLOR_ICON);
      if (hint) {
        hint.textContent = cat
          ? `${cat.name} — ${cat.count} skills · tap again to show all`
          : 'Languages, frameworks, infrastructure & platforms — tap a category to filter.';
      }
    }

    cards.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-cat');
        active = active === key ? null : key;
        render(active);
        cards.forEach((b) => {
          const on = b.getAttribute('data-cat') === active;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', String(on));
        });
      });
    });
  })();
</script>
