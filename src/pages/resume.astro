---
import Layout from '../layouts/Layout.astro';
import { experience } from '../data/experience';
import { skillCategories } from '../data/skills';
import { education } from '../data/education';
import { community, communityNote, clients, trainingTopics, trainingNote, courseOutlinesUrl } from '../data/community';
import { yearsOfExperience } from '../data/profile';

const contacts = [
  { label: 'algogrit@gmail.com', href: 'mailto:algogrit@gmail.com' },
  { label: 'github.com/algogrit', href: 'https://github.com/algogrit' },
  { label: 'algogrit.com', href: 'https://algogrit.com' },
];
const last = experience.length - 1;
---

<Layout
  title="Gaurav Agarwal · Résumé"
  description="Résumé of Gaurav Agarwal, Director of Engineering: distributed systems, training and consulting."
  aurora
>
  <!-- Action bar (screen only) -->
  <div class="no-print fixed top-0 inset-x-0 z-50 backdrop-blur-xl bg-white/50 dark:bg-zinc-950/40 border-b border-zinc-200/60 dark:border-white/5">
    <div class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">
      <a href="/" class="text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">← algogrit.com</a>
      <button
        id="print-btn"
        class="px-4 py-1.5 rounded-full text-xs font-semibold text-white grad-bg hover:opacity-90 transition-opacity inline-flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M6 9V2h12v7" /><rect x="6" y="14" width="12" height="8" /><path d="M6 18H4a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-2" />
        </svg>
        Download PDF
      </button>
    </div>
  </div>

  <main class="resume-doc max-w-4xl mx-auto px-6 pt-28 pb-24">
    <!-- Header -->
    <header class="pdf-item">
      <h1 class="display text-5xl md:text-6xl font-bold">Gaurav Agarwal</h1>
      <p class="mt-2 text-lg grad font-semibold">Director of Engineering · Trainer · Consultant</p>
      <p class="mt-5 max-w-2xl text-zinc-600 dark:text-zinc-300 leading-relaxed">
        Polyglot engineer with {yearsOfExperience}+ years building distributed systems, training 3000+ engineers and
        consulting for 35+ enterprises. Founder of Agarwal Consulting, creator of CoderMana.
      </p>
      <div class="mt-5 flex flex-wrap gap-x-5 gap-y-1 text-sm">
        {
          contacts.map((c) => (
            <a href={c.href} class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
              {c.label}
            </a>
          ))
        }
      </div>
    </header>

    <!-- Experience -->
    <section class="mt-16 pdf-section-gap">
      <h2 class="display text-3xl font-bold mb-8">Experience</h2>
      <div class="relative ml-2 space-y-5">
        {
          experience.map((job, i) => (
            <div class="relative pl-8 pdf-pl pdf-item">
              {i !== last && (
                <span class="pdf-rail absolute left-0 -translate-x-1/2 top-7 w-px bg-zinc-200 dark:bg-white/10" style="height: calc(100% + 1.25rem)" aria-hidden="true" />
              )}
              <span
                class:list={[
                  'pdf-rail absolute left-0 -translate-x-1/2 top-7 h-3 w-3 rounded-full ring-4 z-10',
                  job.current ? 'grad-bg ring-fuchsia-500/15' : 'bg-zinc-300 dark:bg-zinc-600 ring-zinc-400/10',
                ]}
                aria-hidden="true"
              />
              <div class="card rounded-2xl p-6">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <h3 class="display text-xl font-bold">{job.position}</h3>
                    {job.link ? (
                      <a href={job.link} class="grad font-semibold">{job.company}</a>
                    ) : (
                      <span class="text-zinc-500 dark:text-zinc-400 font-medium">{job.company}</span>
                    )}
                  </div>
                  <div class="flex items-center gap-2 text-xs shrink-0">
                    {job.current && <span class="px-2.5 py-1 rounded-full grad-bg text-white font-medium">Current</span>}
                    <span class="px-2.5 py-1 rounded-full bg-zinc-100 dark:bg-white/5 text-zinc-500 dark:text-zinc-400">{job.period}</span>
                  </div>
                </div>
                <p class="mt-3 text-zinc-600 dark:text-zinc-400 text-sm">{job.description}</p>
                {job.achievements.length > 0 && (
                  <ul class="mt-4 space-y-2 text-sm text-zinc-600 dark:text-zinc-300">
                    {job.achievements.map((a) => (
                      <li class="flex gap-2.5"><span class="grad font-bold">→</span>{a}</li>
                    ))}
                  </ul>
                )}
                {job.projects && job.projects.length > 0 && (
                  <div class="mt-5 space-y-3">
                    <div class="text-xs uppercase tracking-widest text-zinc-400">Notable projects</div>
                    {job.projects.map((p) => (
                      <div class="rounded-xl border border-zinc-200 dark:border-white/5 bg-zinc-50 dark:bg-white/[0.02] p-4">
                        <h4 class="font-semibold text-sm">{p.name}</h4>
                        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">{p.description}</p>
                        <div class="flex flex-wrap gap-1.5 mt-2.5 pdf-tech">
                          {p.technologies.map((t) => (
                            <span class="px-2 py-0.5 rounded-md text-xs bg-zinc-200/70 dark:bg-white/10">{t}</span>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Skills -->
    <section class="mt-16 pdf-section-gap">
      <h2 class="display text-3xl font-bold mb-8">Skills</h2>
      <div class="space-y-3">
        {
          skillCategories.map((cat) => (
            <div class="pdf-item card rounded-2xl p-5 grid sm:grid-cols-[11rem_1fr] gap-x-4 gap-y-2">
              <div class="font-semibold">{cat.name}</div>
              <div class="flex flex-wrap gap-1.5 pdf-tech">
                {cat.skills.map((s) => (
                  <span class="px-2 py-0.5 rounded-md text-xs bg-zinc-100 dark:bg-white/10 text-zinc-600 dark:text-zinc-300">{s.name}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Training -->
    <section class="mt-16 pdf-section-gap">
      <h2 class="display text-3xl font-bold mb-8">Training &amp; Consulting</h2>
      <div class="pdf-item card rounded-2xl p-6">
        <p class="text-sm text-zinc-600 dark:text-zinc-300">{trainingNote}</p>
        <div class="mt-4 flex flex-wrap gap-1.5 pdf-tech">
          {trainingTopics.map((t) => (
            <span class="px-2 py-0.5 rounded-md text-xs bg-zinc-100 dark:bg-white/10 text-zinc-600 dark:text-zinc-300">{t}</span>
          ))}
        </div>
        <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400">
          <span class="font-semibold text-zinc-700 dark:text-zinc-200">Organizations trained:</span>
          {' '}{clients.join(', ')}, and many others.
        </p>
        <a href={courseOutlinesUrl} class="mt-3 inline-block grad font-semibold text-sm">Course outlines: github.com/algogrit/Training</a>
      </div>
    </section>

    <!-- Community & Speaking -->
    <section class="mt-16 pdf-section-gap">
      <h2 class="display text-3xl font-bold mb-8">Community &amp; Speaking</h2>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-5 max-w-2xl">{communityNote}</p>
      <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-2">
        {
          community.map((c) => (
            <li class="pdf-item flex flex-wrap items-baseline gap-x-2 text-sm">
              <span class="grad font-semibold">{c.org}</span>
              <span class="text-zinc-600 dark:text-zinc-300">· {c.role}</span>
              {c.note && <span class="text-zinc-500 dark:text-zinc-400">({c.note})</span>}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Education -->
    <section class="mt-16 pdf-section-gap">
      <h2 class="display text-3xl font-bold mb-8">Education</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {
          education.map((e) => (
            <div class="pdf-item card rounded-2xl p-6">
              <div class="flex items-baseline justify-between gap-3">
                <h3 class="display text-lg font-bold">{e.degree}</h3>
                <span class="shrink-0 text-xs text-zinc-500 dark:text-zinc-400 whitespace-nowrap">{e.period}</span>
              </div>
              <p class="grad font-medium text-sm">{e.institution}</p>
              <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">{e.description}</p>
            </div>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const btn = document.getElementById('print-btn');
      btn && btn.addEventListener('click', () => window.print());
      if (new URLSearchParams(location.search).get('print') === '1') {
        window.addEventListener('load', () => setTimeout(() => window.print(), 400));
      }
    })();
  </script>
</Layout>
