# Copy to .env (gitignored) and fill in.
#
# YouTube Data API v3 key — used client-side by the Talks section to list
# videos from the talks playlist and the @codermana channel. This key ships in
# the built bundle, so it is NOT secret — protect it by restricting it in the
# Google Cloud console:
#   - Application restriction: HTTP referrers -> algogrit.com (+ deploy previews)
#   - API restriction: YouTube Data API v3 only
# Without a key, the Talks section gracefully degrades to channel/playlist links.
#
# NOTE: Astro only exposes vars prefixed PUBLIC_ to client-side code.
PUBLIC_YOUTUBE_API_KEY=

# Optional overrides (defaults are baked into Talks.tsx):
PUBLIC_TALKS_PLAYLIST_ID=PL7qtxrxCQ5DBhg0p9p8nDx58FvFR2GVe2
PUBLIC_CODERMANA_HANDLE=codermana
